# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=groupcup
NEXT_PUBLIC_NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://groupcup:groupcup@localhost:5432/groupcup

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Telegram (get a token from @BotFather) ───────────────────────────────────
TG_BOT_TOKEN=
TG_API_ROOT_URL=https://api.telegram.org
TG_WEBHOOK_URL=https://your-domain.com/api/tg-bot
TG_SECRET_TOKEN=change-me-random-string

# ── Solana (devnet) ──────────────────────────────────────────────────────────
SOLANA_RPC=https://api.devnet.solana.com
# 32-byte hex or base58 key used to encrypt custodial wallet secrets at rest.
WALLET_ENCRYPTION_KEY=change-me-32-byte-secret

# ── TxLINE (devnet score data) ───────────────────────────────────────────────
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TOKEN_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG
# JSON array secret key of the ONE backend service wallet that subscribes to TxLINE.
TXLINE_SERVICE_SECRET_KEY=
# Optional: pre-activated API token so the service skips the on-chain subscribe.
TXLINE_API_TOKEN=

# ── Pot (optional on-chain prize pool) ───────────────────────────────────────
POT_ENABLED=false
# Rake taken from a settled pot, in basis points (250 = 2.5%).
POT_RAKE_BPS=250
# Minimum entry in lamports (0.05 SOL = 50000000).
POT_MIN_ENTRY_LAMPORTS=50000000
