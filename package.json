{
  "name": "groupcup",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "bot": "bun run src/bot/index.ts",
    "set-webhook": "bun run scripts/bot.ts setWebhook",
    "set-commands": "bun run scripts/bot.ts setBotCommands",
    "delete-webhook": "bun run scripts/bot.ts deleteWebhook",
    "demo": "bun run scripts/demo-replay.ts",
    "db:generate": "drizzle-kit generate --dialect postgresql --schema ./src/db/schema.ts --out=./src/db/drizzle",
    "db:push": "drizzle-kit push",
    "db:migrate": "bun run ./src/db/migrate.ts",
    "db:setup": "bun db:generate && bun db:migrate",
    "lint": "eslint"
  },
  "dependencies": {
    "@grammyjs/types": "^3.28.0",
    "chalk": "^5.6.2",
    "drizzle-orm": "^0.45.2",
    "gill": "^0.14.0",
    "grammy": "^1.44.0",
    "hono": "^4.12.28",
    "ioredis": "5.10.1",
    "lucide-react": "^1.23.0",
    "ms": "^2.1.3",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "rate-limiter-flexible": "^11.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "telegram-format": "^3.1.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/ms": "^2.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
